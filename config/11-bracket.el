;; ============================================================
;; 11-bracket.el — 括号自动补全（通用，所有模式）
;; ============================================================
;;
;; 功能：
;;   输入 ( 自动补 )、输入 [ 自动补 ]、输入 { 自动补 }
;;   按退格自动删除匹配的闭括号
;;   内置模块，无需安装任何包
;;
;; 与各语言模式的关系（不冲突）：
;;   electric-pair-mode 通过 post-self-insert-hook 生效
;;   各语言模式的自定义括号绑定（如 racket-insert-closing）
;;   优先级高于 electric-pair-mode，各自正常工作
;; ============================================================

;; ── 通用括号自动匹配 ──
(electric-pair-mode 1)

;; 同时匹配尖括号（如 C++ 的 < >）
;; 注：如果不需要 < > 自动补全，删掉下面这行
(setq electric-pair-pairs '((?< . ?>)))

(provide '11-bracket)
;;; 11-bracket.el ends here
